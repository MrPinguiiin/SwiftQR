PORT=8000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/qrisdinamis

# Optional SwiftQR upstream
SWIFTQR_BASE_URL=
SWIFTQR_CREATE_PATH=/qris
SWIFTQR_API_KEY=

# Optional webhook signature verification
SWIFTQR_WEBHOOK_SECRET=

# Gobiz journals search proxy
GOBIZ_BASE_URL=https://api.gobiz.co.id
GOBIZ_JOURNALS_SEARCH_PATH=/journals/search
GOBIZ_AUTHENTICATION_TYPE=go-id
GOBIZ_BEARER_TOKEN=your_token
GOBIZ_MERCHANT_ID=your_merchant_id
GOBIZ_ORIGIN=https://portal.gofoodmerchant.co.id
GOBIZ_REFERER=https://portal.gofoodmerchant.co.id/
